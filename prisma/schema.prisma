generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  USER
}

enum LeadStatus {
  NEW
  TO_REVIEW
  CONTACT_MISSING
  READY_TO_CONTACT
  CONTACTED
  REPLIED
  INTERESTED
  OFFER_SENT
  FOLLOW_UP
  CUSTOMER
  NOT_INTERESTED
  DO_NOT_CONTACT
  INVALID
}

enum LeadActivityType {
  CREATED
  UPDATED
  STATUS_CHANGED
  NOTE_ADDED
  WEBSITE_CHECKED
  CONTACT_LOGGED
}

enum WordpressStatus {
  DETECTED
  LIKELY
  NOT_DETECTED
  FAILED
}

enum CollectionJobStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

enum DirectoryResultStatus {
  NEW
  CONVERTED
  IGNORED
  DUPLICATE
}

enum ReminderStatus {
  OPEN
  DONE
}

enum ReminderType {
  FOLLOW_UP
  WEBSITE_RECHECK
  GENERAL
}

enum BlocklistType {
  DOMAIN
  EMAIL
  PHONE
  COMPANY
}

enum DirectoryProviderStatus {
  DRAFT
  NEEDS_REVIEW
  APPROVED
  DISABLED
}

enum ContactChannel {
  EMAIL
  PHONE
  WEBSITE_FORM
  LINKEDIN
  OTHER
}

enum ContactDirection {
  OUTGOING
  INCOMING
}

model User {
  id           String    @id @default(cuid())
  name         String
  email        String    @unique
  passwordHash String
  role         Role      @default(USER)
  active       Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  lastLoginAt  DateTime?
  sessions     Session[]
  leadActivities LeadActivity[]
  collectionJobs CollectionJob[]
  reminders Reminder[]
  emailTemplates EmailTemplate[]
  contactLogs ContactLog[]

  @@index([active])
  @@index([role])
}

model Session {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model Lead {
  id           String         @id @default(cuid())
  companyName  String
  contactName  String?
  industry     String?
  street       String?
  postalCode   String?
  city         String?
  state        String?
  country      String         @default("Deutschland")
  phone        String?
  email        String?
  website      String?
  source       String?
  sourceUrl    String?
  status       LeadStatus     @default(NEW)
  notes        String?
  websiteReachable Boolean?
  httpsEnabled Boolean?
  httpRedirectsToHttps Boolean?
  wordpressStatus WordpressStatus?
  hasImpressum Boolean?
  hasPrivacyPolicy Boolean?
  hasContactPage Boolean?
  websiteEmail String?
  websitePhone String?
  websiteCheckNotes String?
  websiteCheckedAt DateTime?
  leadScore Int @default(0)
  leadScoreUpdatedAt DateTime?
  nextFollowUpAt DateTime?
  lastContactedAt DateTime?
  contactCount Int @default(0)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  activities   LeadActivity[]
  directoryResults DirectoryResult[]
  reminders Reminder[]
  contactLogs ContactLog[]

  @@index([companyName])
  @@index([city])
  @@index([status])
  @@index([email])
  @@index([phone])
  @@index([website])
  @@index([nextFollowUpAt])
  @@index([leadScore])
  @@index([lastContactedAt])
}

model EmailTemplate {
  id          String   @id @default(cuid())
  name        String
  subject     String
  body        String
  active      Boolean  @default(true)
  createdById String?
  createdBy   User?    @relation(fields: [createdById], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  contactLogs ContactLog[]

  @@index([active])
  @@index([createdById])
  @@index([name])
}

model ContactLog {
  id          String           @id @default(cuid())
  leadId      String
  lead        Lead             @relation(fields: [leadId], references: [id], onDelete: Cascade)
  userId      String?
  user        User?            @relation(fields: [userId], references: [id], onDelete: SetNull)
  templateId  String?
  template    EmailTemplate?   @relation(fields: [templateId], references: [id], onDelete: SetNull)
  channel     ContactChannel
  direction   ContactDirection @default(OUTGOING)
  subject     String?
  message     String?
  contactedAt DateTime         @default(now())
  createdAt   DateTime         @default(now())

  @@index([leadId])
  @@index([userId])
  @@index([templateId])
  @@index([channel])
  @@index([contactedAt])
}

model Reminder {
  id          String         @id @default(cuid())
  leadId      String
  lead        Lead           @relation(fields: [leadId], references: [id], onDelete: Cascade)
  assignedToId String?
  assignedTo   User?         @relation(fields: [assignedToId], references: [id], onDelete: SetNull)
  type        ReminderType   @default(FOLLOW_UP)
  status      ReminderStatus @default(OPEN)
  dueAt       DateTime
  title       String
  note        String?
  completedAt DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([leadId])
  @@index([assignedToId])
  @@index([status])
  @@index([dueAt])
}

model BlocklistEntry {
  id        String        @id @default(cuid())
  type      BlocklistType
  value     String
  note      String?
  active    Boolean       @default(true)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@unique([type, value])
  @@index([active])
  @@index([type])
}

model SmtpSettings {
  id        String   @id @default("default")
  enabled   Boolean  @default(false)
  host      String?
  port      Int      @default(587)
  secure    Boolean  @default(false)
  user      String?
  password  String?
  fromEmail String?
  fromName  String?
  replyTo   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model DirectoryProviderConfig {
  id                     String                  @id @default(cuid())
  key                    String                  @unique
  name                   String
  websiteUrl             String?
  robotsTxtUrl           String?
  termsUrl               String?
  status                 DirectoryProviderStatus @default(NEEDS_REVIEW)
  crawlDelaySeconds      Int                     @default(10)
  maxResultsPerJob       Int                     @default(25)
  requiresManualApproval Boolean                 @default(true)
  robotsTxtReviewedAt    DateTime?
  termsReviewedAt        DateTime?
  licensedAccessReviewedAt DateTime?
  privacyReviewedAt      DateTime?
  reviewCompletedAt      DateTime?
  notes                  String?
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt

  @@index([status])
  @@index([key])
}

model CollectionJob {
  id          String              @id @default(cuid())
  provider    String
  industry    String
  country     String              @default("Deutschland")
  state       String?
  city        String?
  postalCode  String?
  limit       Int                 @default(10)
  status      CollectionJobStatus @default(PENDING)
  error       String?
  createdById String?
  createdBy   User?               @relation(fields: [createdById], references: [id], onDelete: SetNull)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  startedAt   DateTime?
  finishedAt  DateTime?
  results     DirectoryResult[]

  @@index([provider])
  @@index([status])
  @@index([createdAt])
}

model DirectoryResult {
  id          String                @id @default(cuid())
  jobId       String
  job         CollectionJob         @relation(fields: [jobId], references: [id], onDelete: Cascade)
  leadId      String?
  lead        Lead?                 @relation(fields: [leadId], references: [id], onDelete: SetNull)
  externalId  String?
  source      String
  sourceUrl   String?
  companyName String
  industry    String?
  street      String?
  postalCode  String?
  city        String?
  state       String?
  country     String                @default("Deutschland")
  phone       String?
  email       String?
  website     String?
  status      DirectoryResultStatus @default(NEW)
  duplicateReason String?
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt

  @@index([jobId])
  @@index([leadId])
  @@index([source])
  @@index([status])
  @@index([companyName])
}

model LeadActivity {
  id        String           @id @default(cuid())
  leadId    String
  lead      Lead             @relation(fields: [leadId], references: [id], onDelete: Cascade)
  userId    String?
  user      User?            @relation(fields: [userId], references: [id], onDelete: SetNull)
  type      LeadActivityType
  oldValue  String?
  newValue  String?
  note      String?
  createdAt DateTime         @default(now())

  @@index([leadId])
  @@index([userId])
  @@index([type])
  @@index([createdAt])
}
