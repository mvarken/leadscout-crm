generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  USER
}

enum LeadStatus {
  NEW
  TO_REVIEW
  CONTACT_MISSING
  READY_TO_CONTACT
  CONTACTED
  REPLIED
  INTERESTED
  OFFER_SENT
  FOLLOW_UP
  CUSTOMER
  NOT_INTERESTED
  DO_NOT_CONTACT
  INVALID
}

enum LeadActivityType {
  CREATED
  UPDATED
  STATUS_CHANGED
  NOTE_ADDED
  WEBSITE_CHECKED
}

enum WordpressStatus {
  DETECTED
  LIKELY
  NOT_DETECTED
  FAILED
}

enum CollectionJobStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

enum DirectoryResultStatus {
  NEW
  CONVERTED
  IGNORED
  DUPLICATE
}

model User {
  id           String    @id @default(cuid())
  name         String
  email        String    @unique
  passwordHash String
  role         Role      @default(USER)
  active       Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  lastLoginAt  DateTime?
  sessions     Session[]
  leadActivities LeadActivity[]
  collectionJobs CollectionJob[]

  @@index([active])
  @@index([role])
}

model Session {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model Lead {
  id           String         @id @default(cuid())
  companyName  String
  contactName  String?
  industry     String?
  street       String?
  postalCode   String?
  city         String?
  state        String?
  country      String         @default("Deutschland")
  phone        String?
  email        String?
  website      String?
  source       String?
  sourceUrl    String?
  status       LeadStatus     @default(NEW)
  notes        String?
  websiteReachable Boolean?
  httpsEnabled Boolean?
  httpRedirectsToHttps Boolean?
  wordpressStatus WordpressStatus?
  hasImpressum Boolean?
  hasPrivacyPolicy Boolean?
  hasContactPage Boolean?
  websiteEmail String?
  websitePhone String?
  websiteCheckNotes String?
  websiteCheckedAt DateTime?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  activities   LeadActivity[]
  directoryResults DirectoryResult[]

  @@index([companyName])
  @@index([city])
  @@index([status])
  @@index([email])
  @@index([phone])
  @@index([website])
}

model CollectionJob {
  id          String              @id @default(cuid())
  provider    String
  industry    String
  country     String              @default("Deutschland")
  state       String?
  city        String?
  postalCode  String?
  limit       Int                 @default(10)
  status      CollectionJobStatus @default(PENDING)
  error       String?
  createdById String?
  createdBy   User?               @relation(fields: [createdById], references: [id], onDelete: SetNull)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  startedAt   DateTime?
  finishedAt  DateTime?
  results     DirectoryResult[]

  @@index([provider])
  @@index([status])
  @@index([createdAt])
}

model DirectoryResult {
  id          String                @id @default(cuid())
  jobId       String
  job         CollectionJob         @relation(fields: [jobId], references: [id], onDelete: Cascade)
  leadId      String?
  lead        Lead?                 @relation(fields: [leadId], references: [id], onDelete: SetNull)
  externalId  String?
  source      String
  sourceUrl   String?
  companyName String
  industry    String?
  street      String?
  postalCode  String?
  city        String?
  state       String?
  country     String                @default("Deutschland")
  phone       String?
  email       String?
  website     String?
  status      DirectoryResultStatus @default(NEW)
  duplicateReason String?
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt

  @@index([jobId])
  @@index([leadId])
  @@index([source])
  @@index([status])
  @@index([companyName])
}

model LeadActivity {
  id        String           @id @default(cuid())
  leadId    String
  lead      Lead             @relation(fields: [leadId], references: [id], onDelete: Cascade)
  userId    String?
  user      User?            @relation(fields: [userId], references: [id], onDelete: SetNull)
  type      LeadActivityType
  oldValue  String?
  newValue  String?
  note      String?
  createdAt DateTime         @default(now())

  @@index([leadId])
  @@index([userId])
  @@index([type])
  @@index([createdAt])
}
